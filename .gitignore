# This file tells Git which files and folders to ignore.

# Ignore the final packaged LÖVE game file.
*.love

# Ignore OS-specific temporary or metadata files.
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Ignore folders used for build output and releases.
/build/
/releases/
/dist/

# Ignore configuration files from various code editors.
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# Ignore img or other large assets

/assets/sprites/
/assets/wallpaper/
/assets/backgrounds/
/assets/wads/
/assets/boxart/

# Ignore documentation folder
/documentation/

# Ignore generated session metadata
/sessions/

# Ignore audio assets (generated, like sprites)
/assets/audio/

# Ignore audio generation session data
/assets/data/audio_generation_sessions/

# Ignore sprite generation session data (may contain API keys)
/assets/data/sprite_generation_sessions/

# Ignore variant backups
assets/data/variants/*_backup.json

# Ignore generation scripts
/scripts/

# Ignore Claude settings (may contain API keys in permission rules)
.claude/settings.local.json

# Ignore env files
.env
.env.*