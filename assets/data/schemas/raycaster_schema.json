{
    "name": "raycaster_schema",
    "description": "Schema for 3D raycaster maze game parameters",
    "parameters": {
        "maze_width": {
            "type": "integer",
            "default": 15,
            "min": 5,
            "max": 50,
            "description": "Maze cell width (output is 2x+1)"
        },
        "maze_height": {
            "type": "integer",
            "default": 15,
            "min": 5,
            "max": 50,
            "description": "Maze cell height (output is 2x+1)"
        },
        "change_direction": {
            "type": "integer",
            "default": 30,
            "min": 1,
            "max": 100,
            "description": "Chance to change direction (1-30 = winding, 30+ = straight)"
        },
        "sparseness": {
            "type": "integer",
            "default": 70,
            "min": 0,
            "max": 99,
            "description": "How sparse the maze is (25-70 typical)"
        },
        "dead_end_removal": {
            "type": "integer",
            "default": 50,
            "min": 0,
            "max": 99,
            "description": "Chance to remove dead ends (50-99)"
        },
        "room_count": {
            "type": "integer",
            "default": 2,
            "min": 0,
            "max": 10,
            "description": "Number of rooms to generate"
        },
        "room_min_size": {
            "type": "integer",
            "default": 2,
            "min": 1,
            "max": 5,
            "description": "Minimum room dimension"
        },
        "room_max_size": {
            "type": "integer",
            "default": 4,
            "min": 2,
            "max": 10,
            "description": "Maximum room dimension"
        },
        "move_speed": {
            "type": "number",
            "default": 3.0,
            "min": 1.0,
            "max": 10.0,
            "description": "Player movement speed"
        },
        "turn_speed": {
            "type": "number",
            "default": 150,
            "min": 30,
            "max": 360,
            "description": "Turn speed in degrees per second"
        },
        "fov": {
            "type": "number",
            "default": 60,
            "min": 30,
            "max": 120,
            "description": "Field of view in degrees"
        },
        "ray_count": {
            "type": "integer",
            "default": 320,
            "min": 80,
            "max": 640,
            "description": "Number of rays to cast (affects quality)"
        },
        "render_distance": {
            "type": "integer",
            "default": 20,
            "min": 5,
            "max": 50,
            "description": "How far walls render before fading"
        },
        "wall_height": {
            "type": "number",
            "default": 1.0,
            "min": 0.5,
            "max": 2.0,
            "description": "Wall height multiplier"
        },
        "ceiling_color": {
            "type": "array",
            "default": [0.2, 0.2, 0.3],
            "description": "Ceiling color RGB"
        },
        "floor_color": {
            "type": "array",
            "default": [0.3, 0.25, 0.2],
            "description": "Floor color RGB"
        },
        "wall_color_ns": {
            "type": "array",
            "default": [0.7, 0.2, 0.2],
            "description": "North/South wall color RGB"
        },
        "wall_color_ew": {
            "type": "array",
            "default": [0.2, 0.2, 0.7],
            "description": "East/West wall color RGB"
        },
        "goal_color": {
            "type": "array",
            "default": [0.2, 0.9, 0.3],
            "description": "Goal marker color RGB"
        },
        "door_color": {
            "type": "array",
            "default": [0.5, 0.35, 0.2],
            "description": "Door color RGB (brown/wooden)"
        },
        "door_open_distance": {
            "type": "number",
            "default": 1.5,
            "min": 0.5,
            "max": 3.0,
            "description": "Distance from door at which it auto-opens"
        },
        "door_open_speed": {
            "type": "number",
            "default": 3.0,
            "min": 0.5,
            "max": 10.0,
            "description": "How fast doors open (1 = 1 second to fully open)"
        },
        "show_minimap": {
            "type": "boolean",
            "default": true,
            "description": "Show minimap in corner"
        },
        "minimap_size": {
            "type": "integer",
            "default": 150,
            "min": 50,
            "max": 300,
            "description": "Minimap size in pixels"
        },
        "minimap_show_enemies": {
            "type": "boolean",
            "default": false,
            "description": "Show enemies on minimap"
        },
        "difficulty_modifier": {
            "type": "number",
            "default": 1.0,
            "min": 0.5,
            "max": 3.0,
            "description": "Global difficulty multiplier"
        },
        "generator": {
            "type": "string",
            "default": "divided_maze",
            "enum": ["uniform", "digger", "rogue", "cellular", "divided_maze", "icey_maze", "eller_maze", "arena", "static"],
            "description": "Map generator: uniform/digger (rooms), rogue (grid), cellular (caves), *_maze (pure mazes), arena (open), static (predefined)"
        },
        "map_name": {
            "type": "string",
            "default": "pacman",
            "description": "For static generator: name of map file in assets/data/maps/ (without .json)"
        },
        "enable_edge_wrap": {
            "type": "boolean",
            "default": false,
            "description": "Enable Pac-Man style portal wrapping at map edges"
        },
        "room_dug_percentage": {
            "type": "number",
            "default": 0.5,
            "min": 0.1,
            "max": 0.9,
            "description": "For rotLove generators: fraction of map that should be rooms"
        },
        "cell_width": {
            "type": "integer",
            "default": 3,
            "min": 2,
            "max": 10,
            "description": "For rogue generator: number of room columns in grid"
        },
        "cell_height": {
            "type": "integer",
            "default": 3,
            "min": 2,
            "max": 10,
            "description": "For rogue generator: number of room rows in grid"
        },
        "cellular_iterations": {
            "type": "integer",
            "default": 4,
            "min": 1,
            "max": 10,
            "description": "For cellular generator: automata iterations (more = smoother caves)"
        },
        "cellular_prob": {
            "type": "number",
            "default": 0.45,
            "min": 0.3,
            "max": 0.6,
            "description": "For cellular generator: initial floor probability"
        },
        "cellular_connected": {
            "type": "boolean",
            "default": true,
            "description": "For cellular generator: ensure all areas are connected"
        },
        "map_seed": {
            "type": "integer",
            "default": null,
            "min": 1,
            "max": 999999999,
            "description": "Fixed seed for reproducible maps (null = random)"
        },
        "victory_condition": {
            "type": "enum",
            "values": ["goal", "dots", "none"],
            "default": "goal",
            "description": "Win condition: goal (reach exit), dots (collect all), or none (endless)"
        },
        "movement_mode": {
            "type": "string",
            "default": "smooth",
            "enum": ["smooth", "grid"],
            "description": "Movement style: smooth FPS or grid-based dungeon crawler"
        },
        "grid_move_time": {
            "type": "number",
            "default": 0.15,
            "min": 0.05,
            "max": 0.5,
            "description": "Animation time for one tile movement (grid mode)"
        },
        "grid_turn_time": {
            "type": "number",
            "default": 0.12,
            "min": 0.05,
            "max": 0.3,
            "description": "Animation time for 90-degree turn (grid mode)"
        },
        "grid_hold_to_move": {
            "type": "boolean",
            "default": false,
            "description": "Grid mode: if true, holding a key auto-repeats movement. If false (default), requires discrete key presses."
        },
        "room_spawns": {
            "type": "array",
            "default": [],
            "description": "Spawn configs for rooms. Each: {type, count, room_chance (0-1), position (center/random/corners), min_rooms, max_rooms}"
        },
        "corridor_spawns": {
            "type": "array",
            "default": [],
            "description": "Spawn configs for corridor tiles (non-room floors). Each: {type, count, tile_chance (0-1), min_count, max_count}"
        },
        "floor_spawns": {
            "type": "array",
            "default": [],
            "description": "Spawn configs for any floor tile. Each: {type, density (spawns per N tiles), min_count, max_count}"
        },
        "entity_types": {
            "type": "object",
            "default": {},
            "description": "Visual definitions for spawned entities. Each key: {color, height, aspect, y_offset, shape (diamond/square/circle)}"
        },
        "shooting_enabled": {
            "type": "boolean",
            "default": false,
            "description": "Enable shooting with space bar"
        },
        "bullet_speed": {
            "type": "number",
            "default": 8.0,
            "min": 2.0,
            "max": 20.0,
            "description": "Projectile travel speed"
        },
        "bullet_lifetime": {
            "type": "number",
            "default": 3.0,
            "min": 0.5,
            "max": 10.0,
            "description": "How long bullets live before despawning"
        },
        "fire_rate": {
            "type": "number",
            "default": 3.0,
            "min": 0.5,
            "max": 20.0,
            "description": "Shots per second (legacy, use pistol_fire_rate)"
        },
        "pistol_fire_rate": {
            "type": "number",
            "default": 1.5,
            "min": 0.5,
            "max": 5.0,
            "description": "Pistol shots per second (slow, accurate)"
        },
        "machinegun_fire_rate": {
            "type": "number",
            "default": 8.0,
            "min": 2.0,
            "max": 20.0,
            "description": "Machine gun shots per second (fast)"
        },
        "machinegun_bullet_speed": {
            "type": "number",
            "default": 10.0,
            "min": 5.0,
            "max": 20.0,
            "description": "Machine gun bullet speed"
        },
        "machinegun_bullet_color": {
            "type": "array",
            "default": [1, 0.5, 0],
            "description": "Machine gun bullet color RGB (orange)"
        },
        "bullet_color": {
            "type": "array",
            "default": [1, 1, 0],
            "description": "Bullet color RGB"
        },
        "ammo_enabled": {
            "type": "boolean",
            "default": false,
            "description": "Enable ammo system (can't shoot at 0)"
        },
        "starting_ammo": {
            "type": "integer",
            "default": 10,
            "min": 0,
            "max": 99,
            "description": "Starting ammo count"
        },
        "ammo_capacity": {
            "type": "integer",
            "default": 99,
            "min": 1,
            "max": 999,
            "description": "Maximum ammo"
        },
        "ammo_pickup_amount": {
            "type": "integer",
            "default": 5,
            "min": 1,
            "max": 50,
            "description": "Ammo gained per pickup"
        },
        "knife_enabled": {
            "type": "boolean",
            "default": true,
            "description": "Enable knife melee weapon (always available when shooting enabled)"
        },
        "knife_fire_rate": {
            "type": "number",
            "default": 2.0,
            "min": 0.5,
            "max": 10.0,
            "description": "Knife attacks per second"
        },
        "knife_speed": {
            "type": "number",
            "default": 15.0,
            "min": 5.0,
            "max": 30.0,
            "description": "Knife projectile speed (fast, short range)"
        },
        "knife_lifetime": {
            "type": "number",
            "default": 0.035,
            "min": 0.02,
            "max": 0.5,
            "description": "Knife projectile lifetime (very short)"
        },
        "knife_color": {
            "type": "array",
            "default": [0.8, 0.8, 0.8],
            "description": "Knife projectile color RGB"
        },
        "enemy_ai_enabled": {
            "type": "boolean",
            "default": false,
            "description": "Enable enemy AI (line of sight detection, shooting)"
        },
        "enemy_fire_rate": {
            "type": "number",
            "default": 0.5,
            "min": 0.1,
            "max": 5.0,
            "description": "Enemy shots per second when active"
        },
        "enemy_bullet_speed": {
            "type": "number",
            "default": 5.0,
            "min": 1.0,
            "max": 15.0,
            "description": "Enemy projectile speed"
        },
        "enemy_bullet_color": {
            "type": "array",
            "default": [1, 0.3, 0.3],
            "description": "Enemy bullet color RGB (red)"
        },
        "enemy_bullet_damage_min": {
            "type": "integer",
            "default": 5,
            "min": 1,
            "max": 50,
            "description": "Minimum damage per enemy bullet"
        },
        "enemy_bullet_damage_max": {
            "type": "integer",
            "default": 10,
            "min": 1,
            "max": 50,
            "description": "Maximum damage per enemy bullet"
        },
        "enemy_accuracy": {
            "type": "number",
            "default": 0.7,
            "min": 0.1,
            "max": 1.0,
            "description": "Enemy aim accuracy (1.0 = perfect)"
        },
        "enemy_sight_range": {
            "type": "number",
            "default": 15,
            "min": 3,
            "max": 30,
            "description": "How far enemies can see the player"
        },
        "enemy_move_speed": {
            "type": "number",
            "default": 1.0,
            "min": 0.5,
            "max": 8.0,
            "description": "Enemy movement speed during chase"
        },
        "player_health": {
            "type": "integer",
            "default": 100,
            "min": 1,
            "max": 999,
            "description": "Starting player health"
        },
        "health_pickup_amount": {
            "type": "integer",
            "default": 25,
            "min": 1,
            "max": 100,
            "description": "Health restored per health pickup"
        },
        "player_damage_mode": {
            "type": "string",
            "default": "origin",
            "enum": ["origin", "player", "fixed"],
            "description": "How player bullet damage is calculated: origin (distance from shot origin), player (distance from current player pos), fixed (flat damage)"
        },
        "player_bullet_damage": {
            "type": "integer",
            "default": 15,
            "min": 1,
            "max": 100,
            "description": "Fixed damage per bullet (used when player_damage_mode is 'fixed')"
        },
        "weighted_spawns": {
            "type": "object",
            "default": {},
            "description": "Map base spawn type to weighted alternatives. E.g. {\"enemy\": [{\"name\": \"guard\", \"weight\": 70}, {\"name\": \"elite\", \"weight\": 30}]}"
        }
    },
    "components": {
        "movement_controller": {
            "type": "MovementController",
            "config": {
                "speed": "$move_speed",
                "rotation_speed": "$turn_speed"
            }
        },
        "hud": {
            "type": "HUDRenderer",
            "config": {
                "primary": {"label": "Time", "key": "time_elapsed", "format": "time"}
            }
        },
        "visual_effects": {
            "type": "VisualEffects",
            "config": {
                "camera_shake_enabled": false,
                "screen_flash_enabled": true,
                "particle_effects_enabled": false
            }
        }
    },
    "victory_conditions": {
        "goal": {
            "victory": {"type": "threshold", "metric": "goal_reached", "target": 1},
            "loss": {"type": "none"}
        },
        "dots": {
            "victory": {"type": "threshold", "metric": "dots_collected", "target": "$total_dots"},
            "loss": {"type": "none"}
        },
        "none": {
            "victory": {"type": "none"},
            "loss": {"type": "none"}
        }
    }
}
