{
    "name": "dodge_schema",
    "description": "Schema for Dodge game parameters - all configurable values for dodge variants",
    "parameters": {
        "use_rotation": {
            "type": "boolean",
            "default": false,
            "description": "Left/right keys rotate player facing"
        },
        "use_thrust": {
            "type": "boolean",
            "default": false,
            "description": "Up key applies thrust in facing direction"
        },
        "use_reverse_thrust": {
            "type": "boolean",
            "default": false,
            "description": "Down key applies thrust in reverse direction"
        },
        "use_brake": {
            "type": "boolean",
            "default": false,
            "description": "Down key applies strong friction (braking)"
        },
        "use_jump": {
            "type": "boolean",
            "default": false,
            "description": "Directional keys trigger discrete jumps"
        },
        "use_directional": {
            "type": "boolean",
            "default": true,
            "description": "Directional keys move player directly"
        },
        "use_velocity": {
            "type": "boolean",
            "default": false,
            "description": "Apply velocity to position each frame (for momentum)"
        },
        "use_bounce": {
            "type": "boolean",
            "default": false,
            "description": "Bounce off arena walls"
        },
        "movement_speed": {
            "type": "number",
            "default": 300,
            "min": 100,
            "max": 1000,
            "description": "Base movement speed in pixels per second"
        },
        "rotation_speed": {
            "type": "number",
            "default": 8.0,
            "min": 0.5,
            "max": 20,
            "description": "Rotation speed for asteroids mode (radians per second)"
        },
        "max_speed": {
            "type": "number",
            "default": 600,
            "min": 100,
            "max": 1500,
            "description": "Maximum velocity cap"
        },
        "accel_friction": {
            "type": "number",
            "default": 1.0,
            "min": 0.5,
            "max": 1.0,
            "description": "Friction when accelerating (1.0 = instant, <1.0 = gradual buildup)"
        },
        "decel_friction": {
            "type": "number",
            "default": 1.0,
            "min": 0.5,
            "max": 1.0,
            "description": "Friction when decelerating (1.0 = instant stop, <1.0 = drift/slide)"
        },
        "thrust_acceleration": {
            "type": "number",
            "default": 600,
            "min": 100,
            "max": 3000,
            "description": "Thrust acceleration for asteroids movement mode (pixels/sec²)"
        },
        "bounce_damping": {
            "type": "number",
            "default": 0.5,
            "min": 0,
            "max": 1.0,
            "description": "Energy retained on wall bounce (0 = no bounce, 1.0 = full bounce)"
        },
        "jump_distance": {
            "type": "number",
            "default": 80,
            "min": 20,
            "max": 300,
            "description": "Jump mode: distance per jump in pixels"
        },
        "jump_cooldown": {
            "type": "number",
            "default": 0.5,
            "min": 0.1,
            "max": 2.0,
            "description": "Jump mode: seconds between jumps"
        },
        "jump_speed": {
            "type": "number",
            "default": 800,
            "min": 200,
            "max": 2000,
            "description": "Jump mode: speed of jump animation in pixels per second"
        },
        "player_size": {
            "type": "number",
            "default": 1.0,
            "min": 0.5,
            "max": 3.0,
            "description": "Player size multiplier (affects hitbox)"
        },
        "player_auto_fire_interval": {
            "type": "number",
            "default": 0,
            "min": 0,
            "max": 10,
            "description": "Auto-fire interval in seconds (0 = disabled). Player fires projectile forward automatically."
        },
        "player_projectile_speed": {
            "type": "number",
            "default": 400,
            "min": 100,
            "max": 1000,
            "description": "Speed of player auto-fire projectiles"
        },
        "lives": {
            "type": "integer",
            "default": 10,
            "min": 1,
            "max": 99,
            "description": "Starting lives/hits before game over"
        },
        "shield": {
            "type": "integer",
            "default": 0,
            "min": 0,
            "max": 10,
            "description": "Starting shield charges (absorb hits without losing lives)"
        },
        "shield_recharge_time": {
            "type": "number",
            "default": 0,
            "min": 0,
            "max": 60,
            "description": "Seconds to recharge one shield (0 = no recharge)"
        },
        "obstacle_tracking": {
            "type": "number",
            "default": 0.0,
            "min": 0,
            "max": 1.0,
            "description": "How much obstacles home toward player (0 = none, 1.0 = full homing)"
        },
        "obstacle_speed_variance": {
            "type": "number",
            "default": 0.0,
            "min": 0,
            "max": 1.0,
            "description": "Random speed variation for obstacles (0 = uniform, 1.0 = 0-200% speed)"
        },
        "obstacle_spawn_rate": {
            "type": "number",
            "default": 1.0,
            "min": 0.1,
            "max": 5.0,
            "description": "Obstacle spawn rate multiplier (higher = more obstacles)"
        },
        "obstacle_spawn_pattern": {
            "type": "enum",
            "values": ["random", "waves", "spiral", "clusters", "pulse_with_arena"],
            "default": "random",
            "description": "How obstacles spawn into the arena"
        },
        "obstacle_size_variance": {
            "type": "number",
            "default": 0.0,
            "min": 0,
            "max": 1.0,
            "description": "Random size variation for obstacles"
        },
        "obstacle_trails": {
            "type": "integer",
            "default": 0,
            "min": 0,
            "max": 10,
            "description": "Number of trail segments behind obstacles"
        },
        "disable_obstacle_fallback": {
            "type": "boolean",
            "default": false,
            "description": "If true, only spawn enemy types defined in composition (no basic obstacles)"
        },
        "seeker_turn_rate": {
            "type": "number",
            "default": 54,
            "min": 10,
            "max": 180,
            "description": "Turn rate for seeker/chaser enemies in degrees per second"
        },
        "seeker_max_steering_angle": {
            "type": "number",
            "default": null,
            "min": 5,
            "max": 180,
            "description": "Max angle deviation (degrees) from spawn direction for seeker/chaser enemies. Null = unlimited."
        },
        "area_gravity": {
            "type": "number",
            "default": 0.0,
            "min": -500,
            "max": 500,
            "description": "Constant gravity force applied to player (negative = up)"
        },
        "area_gravity_pulse": {
            "type": "boolean",
            "default": false,
            "description": "Oscillate gravity strength with a sine wave (0 to max and back)"
        },
        "area_gravity_pulse_speed": {
            "type": "number",
            "default": 0.5,
            "min": 0.1,
            "max": 5.0,
            "description": "Gravity pulse frequency in Hz"
        },
        "area_gravity_origin": {
            "type": "array",
            "default": null,
            "description": "Gravity pull/push origin as [x_fraction, y_fraction] relative to game area. null = arena center."
        },
        "wind_direction": {
            "type": "number",
            "default": 0,
            "min": 0,
            "max": 360,
            "description": "Wind direction in degrees (0 = right, 90 = down)"
        },
        "wind_strength": {
            "type": "number",
            "default": 0,
            "min": 0,
            "max": 200,
            "description": "Wind force applied to player"
        },
        "wind_type": {
            "type": "enum",
            "values": ["none", "steady", "turbulent", "changing_steady", "changing_turbulent"],
            "default": "none",
            "description": "Wind behavior pattern: steady (constant), turbulent (random variation), changing_steady (rotating direction), changing_turbulent (rotating + random)"
        },
        "fog_of_war_origin": {
            "type": "enum",
            "values": ["none", "player", "center", "circle_center", "mouse"],
            "default": "none",
            "description": "Center point for fog of war visibility"
        },
        "fog_of_war_radius": {
            "type": "number",
            "default": 9999,
            "min": 50,
            "max": 9999,
            "description": "Visibility radius (9999 = full visibility)"
        },
        "camera_shake_intensity": {
            "type": "number",
            "default": 0.0,
            "min": 0,
            "max": 20,
            "description": "Camera shake on collision (0 = none)"
        },
        "player_trail_length": {
            "type": "integer",
            "default": 0,
            "min": 0,
            "max": 50,
            "description": "Visual trail behind player (0 = none)"
        },
        "victory_condition": {
            "type": "enum",
            "values": ["dodge_count", "time", "kills"],
            "default": "dodge_count",
            "description": "Win by dodging N obstacles, surviving time, or destroying N targets"
        },
        "victory_limit": {
            "type": "integer",
            "default": 30,
            "min": 5,
            "max": 500,
            "description": "Target dodge count or survival seconds for victory"
        },
        "victory_progress_weight": {
            "type": "number",
            "default": 1,
            "min": 0.1,
            "max": 10,
            "description": "Multiplier applied to raw metric for victory_progress calculation"
        },
        "arena_base_width": {
            "type": "integer",
            "default": 400,
            "source": "runtime_config.arena.width",
            "description": "Base arena width in pixels"
        },
        "arena_base_height": {
            "type": "integer",
            "default": 400,
            "source": "runtime_config.arena.height",
            "description": "Base arena height in pixels"
        },
        "area_center": {
            "type": "array",
            "default": null,
            "description": "Arena center as [x_fraction, y_fraction] relative to game area. null = center (0.5, 0.5)."
        },
        "area_size": {
            "type": "number",
            "default": 1.0,
            "min": 0.3,
            "max": 2.0,
            "description": "Safe zone size multiplier"
        },
        "area_morph_type": {
            "type": "enum",
            "values": ["shrink", "pulsing", "shape_shifting", "deformation", "none"],
            "default": "shrink",
            "description": "How safe zone changes over time"
        },
        "area_morph_speed": {
            "type": "number",
            "default": 1.0,
            "min": 0.1,
            "max": 5.0,
            "description": "Speed of safe zone morphing"
        },
        "area_movement_speed": {
            "type": "number",
            "default": 1.0,
            "min": 0,
            "max": 5.0,
            "description": "How fast safe zone drifts around (0 = stationary)"
        },
        "area_movement_type": {
            "type": "enum",
            "values": ["none", "random", "cardinal"],
            "default": "random",
            "description": "Pattern of safe zone movement"
        },
        "area_friction": {
            "type": "number",
            "default": 1.0,
            "min": 0.5,
            "max": 1.0,
            "description": "Safe zone movement smoothing"
        },
        "area_shape": {
            "type": "enum",
            "values": ["circle", "square", "hex"],
            "default": "circle",
            "description": "Shape of the safe zone"
        },
        "arena_image": {
            "type": "string",
            "default": null,
            "description": "Path to PNG image defining arena bounds (opaque pixels = playable area)"
        },
        "arena_image_invert": {
            "type": "boolean",
            "default": false,
            "description": "Invert arena image: transparent pixels = playable area instead of opaque"
        },
        "initial_safe_radius_fraction": {
            "type": "number",
            "default": 0.48,
            "min": 0.1,
            "max": 1.0,
            "description": "Initial safe zone radius as fraction of container size"
        },
        "hide_arena": {
            "type": "boolean",
            "default": false,
            "description": "Hide the arena boundary visual (arena still clamps player)"
        },
        "leaving_area_ends_game": {
            "type": "boolean",
            "default": false,
            "description": "Instant death when leaving safe zone (vs taking damage)"
        },
        "holes_type": {
            "type": "enum",
            "values": ["none", "circle", "background"],
            "default": "none",
            "description": "Hole placement: on safe zone boundary or in arena background"
        },
        "holes_count": {
            "type": "integer",
            "default": 0,
            "min": 0,
            "max": 20,
            "description": "Number of holes (danger zones) in arena"
        },
        "bg_image": {
            "type": "string",
            "default": null,
            "description": "Path to background image (for 'image' background type)"
        },
        "bg_color": {
            "type": "array",
            "default": [0.08, 0.05, 0.1],
            "description": "Background base color [r,g,b]"
        },
        "bg_star_color": {
            "type": "array",
            "default": [1, 1, 1],
            "description": "Starfield star color [r,g,b]"
        },
        "bg_star_count": {
            "type": "integer",
            "default": 180,
            "min": 10,
            "max": 500,
            "description": "Number of stars in starfield background"
        },
        "bg_colors": {
            "type": "array",
            "default": null,
            "description": "Shader colors (array of [r,g,b] arrays, 2-4 colors). Used by flowing background."
        },
        "bg_speed": {
            "type": "number",
            "default": 0.4,
            "min": 0.05,
            "max": 3.0,
            "description": "Background animation speed multiplier"
        },
        "bg_scale": {
            "type": "number",
            "default": 1.5,
            "min": 0.2,
            "max": 5.0,
            "description": "Background pattern scale (higher = more zoomed in)"
        },
        "bg_warp": {
            "type": "number",
            "default": 1.0,
            "min": 0.0,
            "max": 3.0,
            "description": "Background distortion intensity"
        },
        "bg_contrast": {
            "type": "number",
            "default": 1.2,
            "min": 0.3,
            "max": 3.0,
            "description": "Background color contrast"
        },
        "bg_interact_radius": {
            "type": "number",
            "default": 0,
            "min": 0,
            "max": 1.0,
            "description": "Enables fluid interaction on background (0 = disabled, any positive = enabled)"
        },
        "bg_point_strength": {
            "type": "number",
            "default": 3.0,
            "min": 0,
            "max": 20.0,
            "description": "How much points displace the background pattern"
        },
        "bg_point_radius": {
            "type": "number",
            "default": 0.008,
            "min": 0.001,
            "max": 0.5,
            "description": "Gaussian falloff radius for point displacement"
        },
        "bg_point_tail": {
            "type": "number",
            "default": 5.0,
            "min": 1.0,
            "max": 20.0,
            "description": "Wake/tail length behind moving points"
        },
        "bg_ink_dye_dissipation": {
            "type": "number",
            "default": 0.997,
            "min": 0.95,
            "max": 1.0,
            "description": "Ink dye fade rate per sim step (1.0 = never fades)"
        },
        "bg_ink_vel_dissipation": {
            "type": "number",
            "default": 0.985,
            "min": 0.9,
            "max": 1.0,
            "description": "Ink velocity fade rate per sim step"
        },
        "bg_ink_diffusion": {
            "type": "number",
            "default": 0.05,
            "min": 0.0,
            "max": 0.5,
            "description": "Ink diffusion/spread rate"
        },
        "bg_ink_amount": {
            "type": "number",
            "default": 0.4,
            "min": 0.05,
            "max": 2.0,
            "description": "Ink injection amount per point"
        },
        "bg_ink_radius": {
            "type": "number",
            "default": 0.0005,
            "min": 0.0001,
            "max": 0.02,
            "description": "Ink injection gaussian radius"
        },
        "bg_ink_vel_strength": {
            "type": "number",
            "default": 3.3,
            "min": 0.1,
            "max": 10.0,
            "description": "Velocity injection strength multiplier"
        },
        "bg_ink_sim_steps": {
            "type": "integer",
            "default": 1,
            "min": 1,
            "max": 6,
            "description": "Ink simulation steps per frame"
        },
        "bg_ink_displace": {
            "type": "number",
            "default": 15.0,
            "min": 0.0,
            "max": 50.0,
            "description": "How much ink velocity displaces the flowing pattern"
        },
        "bg_plasma_layers": {
            "type": "number",
            "default": 4,
            "min": 4,
            "max": 6,
            "description": "Plasma shader sine layers (4 or 6)"
        },
        "bg_ink_dye_color": {
            "type": "array",
            "default": [0.05, 0.02, 0.09],
            "description": "Ink dye color [r,g,b]"
        },
        "use_horizontal_only": {
            "type": "boolean",
            "default": false,
            "description": "Restrict player to left/right movement only (Y locked to center)"
        },
        "horizontal_y_fraction": {
            "type": "number",
            "default": 0.5,
            "min": 0.1,
            "max": 0.95,
            "description": "Where to lock Y for horizontal_only mode as fraction of game height (0.5 = center, 0.9 = near bottom)"
        },
        "spawn_edge": {
            "type": "enum",
            "values": ["any", "top", "bottom", "left", "right"],
            "default": "any",
            "description": "Restrict enemy spawning to one edge (any = all edges)"
        },
        "formation_columns": {
            "type": "integer",
            "default": 0,
            "min": 0,
            "max": 20,
            "description": "Number of formation columns (0 = disabled). Overridden by formation_column_width if set."
        },
        "formation_column_width": {
            "type": "number",
            "default": 0,
            "min": 0,
            "max": 500,
            "description": "Column width in pixels. If > 0, column count = game_width / this value (responsive)."
        },
        "formation_warn_duration": {
            "type": "number",
            "default": 1.0,
            "min": 0.2,
            "max": 5.0,
            "description": "Seconds of warning before formation attack"
        },
        "formation_snap_interval": {
            "type": "number",
            "default": 2.5,
            "min": 0.5,
            "max": 10.0,
            "description": "Seconds between formation attacks (before escalation)"
        },
        "formation_min_safe": {
            "type": "integer",
            "default": 2,
            "min": 1,
            "max": 10,
            "description": "Minimum safe zones per formation attack"
        },
        "formation_escalation_time": {
            "type": "number",
            "default": 30.0,
            "min": 5,
            "max": 120,
            "description": "Seconds to reach maximum formation difficulty"
        },
        "formation_attack_type": {
            "type": "enum",
            "values": ["lunger", "falling"],
            "default": "lunger",
            "description": "What to spawn on formation attack: lunger (teeth from edges) or falling (downward obstacles across columns)"
        },
        "lunge_advance_duration": {
            "type": "number",
            "default": 0.8,
            "min": 0.1,
            "max": 5.0,
            "description": "Seconds for lunger inward movement"
        },
        "lunge_hold_duration": {
            "type": "number",
            "default": 0.15,
            "min": 0,
            "max": 3.0,
            "description": "Seconds lunger holds at target before returning"
        },
        "lunge_return_duration": {
            "type": "number",
            "default": 1.2,
            "min": 0.1,
            "max": 5.0,
            "description": "Seconds for lunger retract movement"
        },
        "lunge_advance_curve": {
            "type": "enum",
            "values": ["linear", "ease_in", "ease_out", "ease_in_out"],
            "default": "ease_out",
            "description": "Easing curve for lunger advance phase"
        },
        "lunge_return_curve": {
            "type": "enum",
            "values": ["linear", "ease_in", "ease_out", "ease_in_out"],
            "default": "ease_in",
            "description": "Easing curve for lunger return phase"
        }
    },
    "components": {
        "hud": {
            "type": "HUDRenderer",
            "config": {
                "primary": {"label": "Dodged", "key": "metrics.objects_dodged"},
                "secondary": {"label": "Time", "key": "time_elapsed", "format": "float"},
                "lives": {"key": "lives", "max": "$lives", "style": "hearts"}
            }
        },
        "fog_controller": {
            "type": "FogOfWar",
            "config": {
                "enabled": true,
                "mode": "stencil",
                "opacity": 0.8
            }
        },
        "visual_effects": {
            "type": "VisualEffects",
            "config": {
                "camera_shake_enabled": true,
                "screen_flash_enabled": true,
                "particle_effects_enabled": true,
                "shake_mode": "exponential",
                "shake_decay": 0.9
            }
        },
        "health_system": {
            "type": "PlayerController",
            "config": {
                "mode": "shield",
                "starting_lives": "$lives",
                "max_lives": 20,
                "shield_enabled": true,
                "shield_max_hits": "$shield",
                "shield_regen_time": "$shield_recharge_time",
                "shield_regen_delay": 0
            }
        }
    },
    "enemy_types": {
        "warning": {
            "name": "warning",
            "category": "warning",
            "type": "static",
            "radius": 0
        },
        "obstacle": {
            "name": "obstacle",
            "category": "obstacle",
            "type": "linear",
            "speed_multiplier": 1.0,
            "on_collision": "damage"
        },
        "chaser": {
            "name": "chaser",
            "category": "obstacle",
            "type": "seeker",
            "speed_multiplier": 0.9,
            "on_collision": "damage"
        },
        "shooter": {
            "name": "shooter",
            "category": "obstacle",
            "type": "shooter",
            "speed_multiplier": 0.7,
            "on_collision": "damage",
            "shoot_interval": 2.0
        },
        "bouncer": {
            "name": "bouncer",
            "category": "obstacle",
            "type": "bouncer",
            "speed_multiplier": 1.0,
            "on_collision": "damage"
        },
        "zigzag": {
            "name": "zigzag",
            "category": "obstacle",
            "type": "zigzag",
            "speed_multiplier": 1.1,
            "on_collision": "damage",
            "wave_speed_min": 2,
            "wave_speed_range": 2,
            "wave_amp": 80
        },
        "teleporter": {
            "name": "teleporter",
            "category": "obstacle",
            "type": "teleporter",
            "speed_multiplier": 0.8,
            "teleport_interval": 3.0,
            "teleport_range": 100,
            "on_collision": "damage"
        },
        "splitter": {
            "name": "splitter",
            "category": "obstacle",
            "type": "splitter",
            "speed_multiplier": 0.8,
            "on_collision": "damage",
            "shards_count": 3,
            "shard_speed_factor": 0.36,
            "shard_radius_factor": 0.6,
            "shard_radius_min": 6,
            "spread_deg": 35
        },
        "lunger": {
            "name": "lunger",
            "category": "obstacle",
            "type": "lunger",
            "speed_multiplier": 1.0,
            "on_collision": "damage",
            "lunge_advance_duration": 0.8,
            "lunge_hold_duration": 0.15,
            "lunge_return_duration": 1.2,
            "lunge_advance_curve": "ease_out",
            "lunge_return_curve": "ease_in"
        },
        "ruler": {
            "name": "ruler",
            "category": "obstacle",
            "type": "linear",
            "speed_multiplier": 1.0,
            "on_collision": "damage"
        },
        "hole": {
            "name": "hole",
            "category": "hazard",
            "type": "static",
            "radius": 8,
            "on_collision": "instant_death",
